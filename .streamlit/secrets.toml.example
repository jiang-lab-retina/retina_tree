# Copy to `.streamlit/secrets.toml` (never commit the real file).
# Streamlit Cloud: paste these keys in the app's Secrets manager.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "replace-with-a-long-random-string"

[auth.google]
client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

# Comma-separated or TOML list of administrator Google emails
[app]
admin_emails = ["admin@your-lab.edu", "pi@your-lab.edu"]
# Local testing only when Google OAuth is not configured
allow_dev_login = true

# Production deploy: set redirect_uri to your public URL, e.g.
# redirect_uri = "https://your-app.streamlit.app/oauth2callback"
