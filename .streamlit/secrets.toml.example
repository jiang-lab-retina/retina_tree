# =============================================================================
# TEMPLATE ONLY — safe to commit. Do NOT put real passwords here.
# =============================================================================
#
# Never commit `.streamlit/secrets.toml` (it is in .gitignore).
#
# Local development (pick one):
#   export RETINA_TREE_ADMIN_PASSWORD='your-strong-password'
#   streamlit run app.py
#
#   OR copy this file to secrets.toml (local only, never push):
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Streamlit Community Cloud:
#   App settings → Secrets → paste only the [app] block below with a real password.
#   Do not upload a secrets.toml file to GitHub.
#
# =============================================================================

[app]
admin_password = "REPLACE_WITH_A_STRONG_PASSWORD"
